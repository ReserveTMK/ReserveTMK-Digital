# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/reservetmk

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── AI — Anthropic ─────────────────────────────────────────────────────────────
AI_INTEGRATIONS_ANTHROPIC_API_KEY=sk-ant-...
# Optional: defaults to https://api.anthropic.com
# AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# ── AI — OpenAI ────────────────────────────────────────────────────────────────
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
# Optional: defaults to https://api.openai.com
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com

# ── AI — AssemblyAI (speech-to-text, primary transcription provider) ───────────
# When set, AssemblyAI is used for transcription instead of OpenAI Whisper.
ASSEMBLYAI_API_KEY=your-key-here

# ── File uploads (local filesystem) ────────────────────────────────────────────
# Directory where uploaded files are stored. Defaults to /tmp/uploads.
# UPLOAD_DIR=/tmp/uploads

# ── Google OAuth (Gmail import) ─────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret

# ── Auth — Replit OIDC (staying for now) ───────────────────────────────────────
# These are injected automatically when running on Replit.
# On Railway, set these manually to match your Replit app.
REPL_ID=your-repl-id
REPLIT_DOMAINS=your-app.replit.app
SESSION_SECRET=change-me-to-a-long-random-string
# OIDC_CLIENT_ID=   # Falls back to REPL_ID if unset
# ISSUER_URL=https://replit.com/oidc
